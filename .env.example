# EgressAI environment. Copy to .env.local and fill in to enable the live Gemini
# path. With NONE of these set, the app runs fully on the deterministic engine
# (every AI feature degrades gracefully). NEVER commit real values.

# Master switch for the generative-AI layer.
USE_GEMINI=false

# --- Option A: Vertex AI (recommended) ---------------------------------------
# Authenticates via Application Default Credentials -- run `gcloud auth
# application-default login` locally, or use the Cloud Run service account. No
# key is stored anywhere.
USE_VERTEX=false
GOOGLE_CLOUD_PROJECT=prompt-wars-srishti
GOOGLE_CLOUD_LOCATION=us-central1

# --- Option B: Gemini Developer API ------------------------------------------
# A single API key from Google AI Studio. Leave blank if using Vertex.
GEMINI_API_KEY=

# Model id (optional; defaults to gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash
